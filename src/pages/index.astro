<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Login | Administrador Kifa</title>
</head>
<body class="bg-dark">
    
    <div class="login-container">
        <div class="glass-card">
            <h1><span class="accent">Kifa</span></h1>
            <p>login</p>
            
            <form id="loginForm">
                <div class="input-group">
                    <label for="user">Usuario</label>
                    <input type="text" id="user" required autocomplete="off" placeholder="ej. ej_ventas">
                </div>
                
                <div class="input-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" required placeholder="••••••••">
                </div>
                <!-- Aquí mostraremos errores en letras rojas si se equivoca -->
                <p id="errorMessage" class="error-text"></p>
                <button type="submit">Entrar</button>
            </form>
        </div>
    </div>
</body>
</html>
<!-- --- PARTE 3: AQUÍ VA EL CSS PURO Y MODERNO PENSADO EN TU APP --- -->
<style>
    /* Importamos una fuente premium */
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap');
    :root {
        --bg-color: #0d1117; /* Súper oscuro */
        --card-bg: rgba(22, 27, 34, 0.7); /* Transparente para efecto cristal */
        --accent: #58a6ff; /* Azul vibrante */
        --text: #e6edf3;
        --text-muted: #8b949e;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
    .bg-dark {
        background-color: var(--bg-color);
        color: var(--text);
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        /* Un fondo con un degradado sutil */
        background-image: radial-gradient(circle at top right, #1f2937, #0d1117);
    }
    .glass-card {
        background: var(--card-bg);
        padding: 2.5rem;
        border-radius: 16px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px); /* Efecto vidrio ahumado */
    }
    h1 { font-size: 1.8rem; margin-bottom: 0.5rem; }
    .accent { color: var(--accent); }
    p { color: var(--text-muted); margin-bottom: 2rem; font-size: 0.9rem; }
    .input-group { margin-bottom: 1.5rem; }
    label { display: block; margin-bottom: 0.5rem; font-size: 0.85rem; font-weight: 600; }
    
    input {
        width: 100%;
        padding: 0.75rem;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(0, 0, 0, 0.2);
        color: white;
        outline: none;
        transition: border 0.3s;
    }
    input:focus { border-color: var(--accent); }
    button {
        width: 100%;
        padding: 0.85rem;
        border: none;
        border-radius: 8px;
        background-color: var(--accent);
        color: #0d1117;
        font-weight: bold;
        font-size: 1rem;
        cursor: pointer;
        transition: transform 0.2s, background-color 0.2s;
    }
    button:hover {
        background-color: #79c0ff;
        transform: translateY(-2px); /* Animación chiquita al pasar el mouse */
    }
    .error-text {
        color: #ff7b72;
        margin-top: 0; margin-bottom: 1rem;
        display: none;
        font-weight: bold;
    }
</style>
<!-- --- PARTE 4: LA LÓGICA DEL CLIENTE (INTERACCIÓN CON TU BACKEND) --- -->
<script>
    const form = document.getElementById('loginForm');
    const errorMsg = document.getElementById('errorMessage');
    // Escuchamos cuando el usuario le da click a Entrar
    form.addEventListener('submit', async (e) => {
        e.preventDefault(); // Evitamos que la página brinque o se recargue
        // Agarramos lo que el usuario escribió
        const user = document.getElementById('user').value;
        const password = document.getElementById('password').value;
        try {
            // ¡EL PUENTE CON TU BACKEND!
            const res = await fetch('http://localhost:4000/api/login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ user, password })
            });
            const data = await res.json();
            if (!res.ok) {
                // Si la VPS batea al usuario, mostramos el error
                errorMsg.textContent = data.message;
                errorMsg.style.display = 'block';
            } else {
                // SI TODO SALIÓ BIEN 🎉
                errorMsg.style.display = 'none';
                
                // 1. Guardamos el Gafete en la "mochila" del navegador (localStorage)
                localStorage.setItem('kifa_token', data.token);
                // 2. Lo mandamos a su panel principal
                window.location.href = '/dashboard';
            }
        } catch (error) {
            errorMsg.textContent = "Error al conectar con el servidor.";
            errorMsg.style.display = 'block';
        }
    });
</script>