---
// Este archivo se renderiza como una página HTML estática en Astro y usa JavaScript Vanilla para comunicarse con tu API.
---
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Dashboard | Administrador Kifa</title>
</head>
<body class="bg-dark">
    <!-- Barra de Navegación -->
    <nav class="navbar">
        <div class="logo">
            <h1 style="cursor:pointer" id="homeLogo"><span class="accent">Kifa</span> Dashboard</h1>
        </div>
        <div class="user-info">
            <span id="welcomeMessage">Cargando...</span>
            <button id="logoutBtn" class="logout-btn">Cerrar Sesión</button>
        </div>
    </nav>

    <!-- Contenido Principal -->
    <main class="container">
        
        <!-- Vista del Listado de Tablas (Tarjetas) -->
        <div id="dashboardHome">
            <header class="dashboard-header">
                <h2>Tus Tablas Accesibles</h2>
                <p>A continuación se muestran las áreas de la base de datos a las que tienes permisos según tu rol.</p>
            </header>
            
            <div id="tablesGrid" class="tables-grid">
                <!-- Cargando -->
                <div class="loading-state">
                    <svg class="spinner" viewBox="0 0 50 50">
                        <circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle>
                    </svg>
                    <p>Verificando permisos y obteniendo tablas...</p>
                </div>
            </div>
            
            <div id="errorDisplay" class="error-state" style="display: none;"></div>
        </div>

        <!-- Vista del Contenido de una Tabla -->
        <div id="tableViewer" style="display: none;">
            <div class="viewer-header">
                <button id="backBtn" class="back-btn">
                    <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" height="20" width="20"><path d="M15 18l-6-6 6-6"></path></svg>
                    Volver
                </button>
                <h2 id="viewerTitle" class="viewer-title">Tabla: <span class="accent">...</span></h2>
            </div>

            <div class="table-container">
                <div id="tableLoading" class="loading-state">
                    <svg class="spinner" viewBox="0 0 50 50"><circle class="path" cx="25" cy="25" r="20" fill="none" stroke-width="5"></circle></svg>
                    <p>Cargando registros...</p>
                </div>
                <!-- Aquí se pintará la tabla -->
                <div id="dataTableWrapper" class="data-table-wrapper" style="display: none;">
                    <table class="kifa-table" id="kifaTable">
                        <thead id="kifaTableHead"></thead>
                        <tbody id="kifaTableBody"></tbody>
                    </table>
                </div>
                <div id="tableError" class="error-state" style="display: none;"></div>
            </div>
        </div>
    </main>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&display=swap');
    
    :root {
        --bg-color: #0d1117;
        --card-bg: rgba(22, 27, 34, 0.7);
        --accent: #58a6ff;
        --text: #e6edf3;
        --text-muted: #8b949e;
        --danger: #ff7b72;
        --border: rgba(255, 255, 255, 0.1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Inter', sans-serif; }
    
    body.bg-dark {
        background-color: var(--bg-color);
        color: var(--text);
        min-height: 100vh;
        background-image: radial-gradient(circle at top right, #1f2937, #0d1117);
        background-attachment: fixed;
    }

    /* Navegación */
    .navbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 3rem;
        background: rgba(13, 17, 23, 0.8);
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(12px);
        position: sticky;
        top: 0;
        z-index: 100;
    }
    .navbar h1 { font-size: 1.5rem; transition: opacity 0.2s; }
    .navbar h1:hover { opacity: 0.8; }
    .accent { color: var(--accent); }
    .user-info { display: flex; align-items: center; gap: 1.5rem; }
    #welcomeMessage { font-weight: 500; color: var(--text-muted); }

    .logout-btn, .back-btn {
        background: transparent;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .logout-btn { color: var(--danger); border: 1px solid var(--danger); }
    .logout-btn:hover { background: var(--danger); color: #fff; }

    .back-btn { color: var(--text); border: 1px solid var(--text-muted); }
    .back-btn:hover { background: rgba(255,255,255,0.1); }

    /* Contenedor */
    .container { max-width: 1100px; margin: 0 auto; padding: 4rem 1.5rem; }

    .dashboard-header { margin-bottom: 3rem; text-align: center; animation: fadeInDown 0.5s ease-out; }
    .dashboard-header h2 { font-size: 2.2rem; margin-bottom: 0.5rem; background: linear-gradient(to right, #58a6ff, #a371f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

    /* Grid de Elementos (Tablas) */
    .tables-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem; }
    .table-card {
        background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px;
        padding: 2.5rem 2rem; text-align: center; backdrop-filter: blur(10px);
        transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s; cursor: pointer;
        display: flex; flex-direction: column; align-items: center; gap: 1rem;
        animation: fadeInUp 0.5s backwards;
    }
    .table-card:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(88, 166, 255, 0.15); border-color: rgba(88, 166, 255, 0.5); }
    .table-icon { width: 56px; height: 56px; background: rgba(88, 166, 255, 0.1); color: var(--accent); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; }
    .table-name { font-size: 1.25rem; font-weight: 600; text-transform: capitalize; color: var(--text); }

    /* Viewer de Datos */
    .viewer-header { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2rem; animation: fadeInDown 0.4s; }
    .viewer-title { font-size: 1.8rem; font-weight: 600; }
    .table-container { background: var(--card-bg); border: 1px solid var(--border); border-radius: 16px; padding: 1.5rem; overflow-x: auto; backdrop-filter: blur(10px); animation: fadeInUp 0.5s; box-shadow: 0 8px 24px rgba(0,0,0,0.5); }
    
    /* Estilos de tabla Real HTML */
    .kifa-table { width: 100%; border-collapse: collapse; text-align: left; }
    .kifa-table th { padding: 1rem; background: rgba(255,255,255,0.05); color: var(--text-muted); font-weight: 500; font-size: 0.9rem; border-bottom: 1px solid var(--border); letter-spacing: 0.5px; text-transform: uppercase; }
    .kifa-table td { padding: 1rem; border-bottom: 1px solid rgba(255,255,255,0.03); color: var(--text); font-size: 0.95rem; }
    .kifa-table tbody tr:hover { background: rgba(88, 166, 255, 0.05); }

    /* Estados */
    .loading-state, .error-state, .empty-state { grid-column: 1 / -1; text-align: center; padding: 4rem 2rem; color: var(--text-muted); background: var(--card-bg); border-radius: 16px; border: 1px dashed var(--border); }
    .error-state { color: var(--danger); border-color: rgba(255, 123, 114, 0.3); }

    /* Spinner */
    @keyframes fadeInDown { from { opacity: 0; transform: translateY(-15px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes fadeInUp { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
    .spinner { animation: rotate 2s linear infinite; z-index: 2; width: 40px; height: 40px; margin: 0 auto 1rem auto; display: block; }
    .spinner .path { stroke: var(--accent); stroke-linecap: round; animation: dash 1.5s ease-in-out infinite; }
    @keyframes rotate { 100% { transform: rotate(360deg); } }
    @keyframes dash { 0% { stroke-dasharray: 1, 150; stroke-dashoffset: 0; } 50% { stroke-dasharray: 90, 150; stroke-dashoffset: -35; } 100% { stroke-dasharray: 90, 150; stroke-dashoffset: -124; } }
</style>

<script>
    const token = localStorage.getItem('kifa_token');
    if (!token) window.location.href = '/';

    const dom = {
        home: document.getElementById('dashboardHome'),
        viewer: document.getElementById('tableViewer'),
        tablesGrid: document.getElementById('tablesGrid'),
        errorDisplay: document.getElementById('errorDisplay'),
        welcomeMsg: document.getElementById('welcomeMessage'),
        viewerTitle: document.getElementById('viewerTitle'),
        tableLoading: document.getElementById('tableLoading'),
        tableWrapper: document.getElementById('dataTableWrapper'),
        tableError: document.getElementById('tableError'),
        thead: document.getElementById('kifaTableHead'),
        tbody: document.getElementById('kifaTableBody'),
        backBtn: document.getElementById('backBtn'),
        homeLogo: document.getElementById('homeLogo'),
        logoutBtn: document.getElementById('logoutBtn')
    };

    dom.logoutBtn.addEventListener('click', () => { localStorage.removeItem('kifa_token'); window.location.href = '/'; });
    
    const goHome = () => {
        dom.viewer.style.display = 'none';
        dom.home.style.display = 'block';
    };

    dom.backBtn.addEventListener('click', goHome);
    dom.homeLogo.addEventListener('click', goHome);

    // 2. Función para pintar los registros de una tabla al clickear su tarjeta
    async function fetchAndRenderTableData(tableName) {
        dom.home.style.display = 'none';
        dom.viewer.style.display = 'block';
        dom.viewerTitle.innerHTML = `Tabla: <span class="accent">${tableName}</span>`;
        dom.tableWrapper.style.display = 'none';
        dom.tableError.style.display = 'none';
        dom.tableLoading.style.display = 'block';
        dom.thead.innerHTML = ''; dom.tbody.innerHTML = '';

        try {
            const res = await fetch(`http://18.224.252.124:4000/api/tables/${tableName}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || "Error al obtener los datos");
            
            dom.tableLoading.style.display = 'none';
            
            // Pintar Columnas
            if(data.columns && data.columns.length > 0) {
                const trHead = document.createElement('tr');
                data.columns.forEach(col => {
                    const th = document.createElement('th');
                    th.textContent = col;
                    trHead.appendChild(th);
                });
                dom.thead.appendChild(trHead);

                // Pintar Filas
                if (data.rows && data.rows.length > 0) {
                    data.rows.forEach(row => {
                        const trBody = document.createElement('tr');
                        data.columns.forEach(col => {
                            const td = document.createElement('td');
                            td.textContent = row[col] !== null ? row[col] : 'NULL';
                            trBody.appendChild(td);
                        });
                        dom.tbody.appendChild(trBody);
                    });
                } else {
                    const trBody = document.createElement('tr');
                    trBody.innerHTML = `<td colspan="${data.columns.length}" style="text-align:center; padding: 3rem; color: #8b949e;">La tabla está vacía. No tiene registros.</td>`;
                    dom.tbody.appendChild(trBody);
                }
                dom.tableWrapper.style.display = 'block';
            }
        } catch(error) {
            dom.tableLoading.style.display = 'none';
            dom.tableError.style.display = 'block';
            dom.tableError.textContent = error.message;
        }
    }

    // 1. Cargar las tablas iniciales
    async function loadDashboard() {
        try {
            const res = await fetch('http://18.224.252.124:4000/api/tables', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || "Error");

            dom.welcomeMsg.innerHTML = `Conectado como <span class="accent">@${data.userLogueado}</span>`;
            dom.tablesGrid.innerHTML = ''; 

            if (!data.tables || data.tables.length === 0) {
                dom.tablesGrid.innerHTML = `<div class="empty-state">No tienes acceso a ninguna tabla en esta base de datos.</div>`;
                return;
            }

            data.tables.forEach((tableName, index) => {
                const card = document.createElement('div');
                card.className = 'table-card';
                card.style.animationDelay = `${index * 0.1}s`; 
                card.innerHTML = `
                    <div class="table-icon">
                        <svg stroke="currentColor" fill="none" stroke-width="2" viewBox="0 0 24 24" height="1em" width="1em">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <line x1="3" y1="9" x2="21" y2="9"></line><line x1="3" y1="15" x2="21" y2="15"></line>
                            <line x1="9" y1="9" x2="9" y2="21"></line><line x1="15" y1="9" x2="15" y2="21"></line>
                        </svg>
                    </div><div class="table-name">${tableName}</div>
                `;
                
                // ¡Al hacer click en la tajeta, pintamos la tabla HTML real!
                card.addEventListener('click', () => fetchAndRenderTableData(tableName));
                dom.tablesGrid.appendChild(card);
            });
        } catch (error) {
            dom.tablesGrid.style.display = 'none';
            dom.errorDisplay.style.display = 'block';
            dom.errorDisplay.textContent = error.message;
            if (error.message.includes("expirado") || error.message.includes("Acceso")) {
                setTimeout(() => { localStorage.removeItem('kifa_token'); window.location.href = '/'; }, 2500);
            }
        }
    }

    loadDashboard();
</script>
</body>
</html>
